        },
        {
            "id": "wavesurfer_7tc95ad488o",
            "startAt": 44464,
            "endAt": 45864,
            "text": "네 집 주소 부르세요.",
            "speaker": 0
        },
        {
            "id": "72305576",
            "startAt": 45927,
            "endAt": 50024,
            "text": "어, 왜왜왜. 왜왜.",
