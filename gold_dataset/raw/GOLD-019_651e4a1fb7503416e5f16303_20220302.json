        {
            "id": "fc29d52b",
            "startAt": 14373,
            "endAt": 16483,
            "text": "아이가 무슨 수술을 했는데요.",
            "speaker": 0
        },
        {
            "id": "9938b20d",
            "startAt": 16843,
            "endAt": 21053,
            "text": "아, 자궁, 그 저 염전 수술을 했었는데.",
            "speaker": 1
        },
        {
            "id": "wavesurfer_uabpivpkvd",
            "startAt": 21090,
            "endAt": 22981,
            "text": "지금 지금 급해 급해가.",
            "speaker": 1
        },
        {
            "id": "3c231301",
            "startAt": 22203,
            "endAt": 24133,
            "text": "지금 급해가 긴급한 상황이에요.",
            "speaker": 1
        },
        {
            "id": "af18023a",
            "startAt": 24763,
            "endAt": 30913,
            "text": "구급차 보내드릴 거니까 지금 환자 의식 있어요. 호흡 없어, 호, 의, 의식, 호흡 어때요?",
            "speaker": 0
        },
        {
            "id": "wavesurfer_tuvpvcbqkfo",
            "startAt": 30221,
            "endAt": 31431,
            "text": "거 의식 빨 빨리 좀.",
            "speaker": 1
        },
        {
            "id": "7d89a4a8",
            "startAt": 31503,
            "endAt": 32428,
            "text": "거의 없어요.",
            "speaker": 1
        },
        {
            "id": "b468ca0f",
            "startAt": 33634,
            "endAt": 36810,
            "text": "강하게 흔들어 깨웠을 때 움찔하거나 그런 반응 없어요?",
            "speaker": 0
