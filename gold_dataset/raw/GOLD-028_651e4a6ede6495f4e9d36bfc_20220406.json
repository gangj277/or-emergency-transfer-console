        },
        {
            "id": "ac516ab2",
            "startAt": 12344,
            "endAt": 13997,
            "text": "아우 저 저거 저.",
            "speaker": 1
        },
        {
            "id": "wavesurfer_i94jsmgs8d8",
            "startAt": 14364,
            "endAt": 17128,
            "text": "십, 십삼년만에. 네, 예.",
            "speaker": 1
        },
        {
            "id": "b906838e",
            "startAt": 14819,
            "endAt": 16490,
            "text": "선생님, 할머니.",
