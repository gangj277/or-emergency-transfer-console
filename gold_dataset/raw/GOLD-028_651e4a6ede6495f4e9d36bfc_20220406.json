        },
        {
            "id": "1921fef1",
            "startAt": 9404,
            "endAt": 12077,
            "text": "아 예, 좀 빨리 좀 와주세요, 할아버지 좀.",
            "speaker": 1
        },
        {
            "id": "265d07a4",
            "startAt": 12050,
