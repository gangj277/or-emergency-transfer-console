        },
        {
            "id": "c8ad3621",
            "startAt": 68374,
            "endAt": 68934,
            "text": "예.",
            "speaker": 0
        },
        {
            "id": "687a2c7e",
            "startAt": 70008,
            "endAt": 71582,
            "text": "여 동철동은 또 어디갔어.",
