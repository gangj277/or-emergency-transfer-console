        },
        {
            "id": "wavesurfer_4aohddv37ig",
            "startAt": 24863,
            "endAt": 26620,
            "text": "이 몇 층 몇 호로 가면 돼요?",
            "speaker": 0
        },
        {
            "id": "wavesurfer_3nvs6i99rpg",
            "startAt": 26947,
            "endAt": 28265,
            "text": "[개인정보]",
            "speaker": 1
        },
        {
