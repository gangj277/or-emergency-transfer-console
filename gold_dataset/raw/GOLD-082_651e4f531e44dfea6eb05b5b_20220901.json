        },
        {
            "id": "wavesurfer_cgaqi0d1b2g",
            "startAt": 85438,
            "endAt": 86708,
            "text": "엄마 어디 아파?",
            "speaker": 1
        },
        {
            "id": "wavesurfer_9jc42ere678",
            "startAt": 87061,
            "endAt": 89941,
            "text": "여보세요, 어린이 뚜드리지 마시고, 지금 어떻게 됀거에요?",
