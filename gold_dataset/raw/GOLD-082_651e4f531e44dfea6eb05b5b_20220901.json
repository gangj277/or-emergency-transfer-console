        },
        {
            "id": "wavesurfer_kert65nkbqo",
            "startAt": 90139,
            "endAt": 91043,
            "text": "그렇지?",
            "speaker": 1
        },
        {
            "id": "wavesurfer_hsrk9g5h8bg",
            "startAt": 92030,
            "endAt": 95445,
            "text": "어머, 어머니 좀 바꿔줘, 몇 살된 아이예요?",
            "speaker": 0
        },
        {
            "id": "wavesurfer_2q7ckt0siu",
            "startAt": 94554,
