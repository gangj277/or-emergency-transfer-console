        },
        {
            "id": "wavesurfer_5o3rn1mv9a",
            "startAt": 41776,
            "endAt": 44248,
            "text": "영석초등학교 옆에 있는 아파트 현대아파트",
            "speaker": 0
        },
        {
            "id": "wavesurfer_bddn4ecg0ag",
            "startAt": 44181,
            "endAt": 44936,
            "text": "네네네.",
