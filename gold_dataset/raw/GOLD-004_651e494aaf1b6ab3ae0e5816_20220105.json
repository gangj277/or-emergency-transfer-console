    "utterances": [
        {
            "id": "ad337cf8",
            "startAt": 1032,
            "endAt": 5058,
            "text": "할아버지 아, 여기 교통사고 났어요, 빨리 좀 와주세요.",
            "speaker": 1
        },
        {
            "id": "53f4dc75",
            "startAt": 5272,
            "endAt": 6448,
            "text": "위치가 어떻게 돼요?",
            "speaker": 0
        },
        {
            "id": "8675ef6d",
            "startAt": 6655,
            "endAt": 13905,
            "text": "여기 남성역 골목시장 앞이여 빨리요 예 차량 예 할아버지 할아버지 예.",
            "speaker": 1
        },
        {
            "id": "wavesurfer_r6nmej5uuh",
            "startAt": 10630,
            "endAt": 13447,
            "text": "차랑 할아버지랑 부딪혔다고 예",
