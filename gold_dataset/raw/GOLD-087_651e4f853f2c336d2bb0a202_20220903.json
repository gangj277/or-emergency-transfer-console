            "endAt": 63267,
            "text": "[개인정보]",
            "speaker": 0
        },
        {
            "id": "wavesurfer_nvshj9llt7o",
            "startAt": 63327,
            "endAt": 64210,
            "text": "주택이에요 빌라예요?",
            "speaker": 0
        },
        {
            "id": "4426eb7a",
            "startAt": 65146,
            "endAt": 65815,
            "text": "주택이요",
            "speaker": 1
        },
        {
