        {
            "id": "df238128",
            "startAt": 16912,
            "endAt": 17798,
            "text": "네, 네.",
            "speaker": 1
        },
        {
            "id": "814f7974",
            "startAt": 17832,
            "endAt": 19236,
            "text": "어 출동했고요 선생님.",
