OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-5.4-mini
NEMC_SERVICE_KEY=your_data_go_kr_service_key
# Kakao Mobility REST API key — build-time only (npm run or:build:travel). The deployed
# app reads the committed travel_time_matrix.json and does NOT need this at runtime.
KAKAO_REST_API_KEY=your_kakao_mobility_rest_api_key
